# App
APP_NAME=AI PDF Service
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS - comma separated origins or *
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# LLM Provider: "ollama" or "openai"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:0.5b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=300

# Ollama (default provider)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (alternative provider)
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Optional: API token for service-to-service auth
# AI_SERVICE_API_TOKEN=your-secure-token-here
