# For local dev, use a local MongoDB instance or Atlas:
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pdf_ai?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d
PORT=5000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpeg,jpg,jpe,jfif,pjpeg,pjp,png,gif,webp,bmp,dib,tiff,tif,svg,svgz,heic,heif,avif,ico,cur,apng,jp2,j2k,jpf,jpx,jpm,mj2,psd,psb,tga,pbm,pgm,ppm,pnm,pfm,ras,xpm,xbm,pct,pict,pic,sgi,rgb,rgba,bw,exr,hdr,pdf
NODE_ENV=production
CORS_ORIGIN=https://your-app.vercel.app

# Production: Set these as env vars in your hosting dashboard (Render/Railway/Heroku)
# MONGODB_URI, JWT_SECRET, NODE_ENV, CORS_ORIGIN must be set there
# CORS_ORIGIN supports comma-separated origins: https://your-app.vercel.app,https://your-custom-domain.com
#
# For the backend on Render, also set:
# REACT_APP_API_URL=https://your-backend.onrender.com/api   (in Vercel env vars)
# CORS_ORIGIN=https://your-app.vercel.app   (in Render env vars — the frontend origin(s) that can call the API)

# OpenAI Configuration (required for PDF Chat / RAG + optional for AI Editor)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# AI Model config (optional)
LLM_MODEL=gpt-4o-mini            # Used by PDF Chat (RAG) and LangChain
