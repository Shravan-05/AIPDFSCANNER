MONGODB_URI=mongodb://localhost:27017/pdf-ai-scanner
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d
PORT=5000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpeg,jpg,png,tiff,bmp,webp,pdf
NODE_ENV=production
CORS_ORIGIN=https://your-vercel-app.vercel.app

# Production: Set these as env vars in your hosting dashboard (Render/Railway/Heroku)
# MONGODB_URI, JWT_SECRET, NODE_ENV, CORS_ORIGIN must be set there
